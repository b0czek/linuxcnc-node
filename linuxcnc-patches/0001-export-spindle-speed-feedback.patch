From d0d257c147629e9dea89a107c7754e16092c35f3 Mon Sep 17 00:00:00 2001
From: Dariusz Majnert <dariusz@users.noreply.github.com>
Date: Sat, 27 Jun 2026 17:36:55 +0200
Subject: [PATCH] emc: expose spindle speed feedback in status

---
 src/emc/nml_intf/emc.cc                       | 1 +
 src/emc/nml_intf/emc_nml.hh                   | 3 ++-
 src/emc/nml_intf/emcops.cc                    | 1 +
 src/emc/task/taskintf.cc                      | 1 +
 src/emc/usr_intf/axis/extensions/emcmodule.cc | 1 +
 5 files changed, 6 insertions(+), 1 deletion(-)

diff --git a/src/emc/nml_intf/emc.cc b/src/emc/nml_intf/emc.cc
index df82c4d0d0..fd5b118fba 100644
--- a/src/emc/nml_intf/emc.cc
+++ b/src/emc/nml_intf/emc.cc
@@ -1014,6 +1014,7 @@ void EMC_SPINDLE_STAT::update(CMS * cms)
 {
     EMC_SPINDLE_STAT_MSG::update(cms);
     cms->update(speed);
+    cms->update(feedback);
     cms->update(spindle_scale);
     cms->update(css_maximum);
     cms->update(css_factor);
diff --git a/src/emc/nml_intf/emc_nml.hh b/src/emc/nml_intf/emc_nml.hh
index afd051e27b..633c3c952b 100644
--- a/src/emc/nml_intf/emc_nml.hh
+++ b/src/emc/nml_intf/emc_nml.hh
@@ -1118,7 +1118,8 @@ class EMC_SPINDLE_STAT:public EMC_SPINDLE_STAT_MSG {
     // cppcheck-suppress duplInheritedMember
     void update(CMS * cms);
 
-    double speed;		// spindle speed in RPMs
+    double speed;		// commanded spindle speed in RPMs
+    double feedback;		// spindle speed feedback in RPM
     double spindle_scale;	// spindle over-ride
     double css_maximum;
     double css_factor;  // CSS Status
diff --git a/src/emc/nml_intf/emcops.cc b/src/emc/nml_intf/emcops.cc
index d58c87c637..6373c42f49 100644
--- a/src/emc/nml_intf/emcops.cc
+++ b/src/emc/nml_intf/emcops.cc
@@ -178,6 +178,7 @@ EMC_AUX_STAT::EMC_AUX_STAT()
 EMC_SPINDLE_STAT::EMC_SPINDLE_STAT()
   : EMC_SPINDLE_STAT_MSG(EMC_SPINDLE_STAT_TYPE, sizeof(EMC_SPINDLE_STAT)),
     speed(0.0),
+    feedback(0.0),
     spindle_scale(1.0),
     css_maximum(0.0),
     css_factor(1.0),
diff --git a/src/emc/task/taskintf.cc b/src/emc/task/taskintf.cc
index 7aaee75fe7..ccbf7b5128 100644
--- a/src/emc/task/taskintf.cc
+++ b/src/emc/task/taskintf.cc
@@ -2036,6 +2036,7 @@ int emcSpindleUpdate(EMC_SPINDLE_STAT stat[], int num_spindles){
 		stat[s].spindle_override_enabled = enables & SS_ENABLED;
 		stat[s].enabled = emcmotStatus.spindle_status[s].speed != 0;
 		stat[s].speed = emcmotStatus.spindle_status[s].speed;
+		stat[s].feedback = emcmotStatus.spindle_status[s].spindleSpeedIn * 60.0;
 		stat[s].brake = emcmotStatus.spindle_status[s].brake;
 		stat[s].direction = emcmotStatus.spindle_status[s].direction;
 		stat[s].orient_state = emcmotStatus.spindle_status[s].orient_state;
diff --git a/src/emc/usr_intf/axis/extensions/emcmodule.cc b/src/emc/usr_intf/axis/extensions/emcmodule.cc
index 0ffaae6b7d..73b9efc2c8 100644
--- a/src/emc/usr_intf/axis/extensions/emcmodule.cc
+++ b/src/emc/usr_intf/axis/extensions/emcmodule.cc
@@ -1425,6 +1425,7 @@ static PyObject *Stat_spindle_one(pyStatChannel *s, int spindleno) {
     F(enabled);
     F2("override_enabled", spindle_override_enabled);
     F(speed);
+    F(feedback);
     F2("override", spindle_scale);
     F(homed);
     F(orient_state);

+        return;
+    }
 	// now handle call logic
 	// check for subsystems done
 	if (interp_list.len() == 0 &&
@@ -745,6 +769,110 @@ static bool allow_while_idle_type() {
     return 0;
 }
 
+static void emcTaskStopClear()
+{
+    bool was_active = emcStatus &&
+        emcStatus->task.stopState != EMC_TASK_STOP_STATE::IDLE;
+    stop_resume_latched = false;
+    stop_outputs_saved = false;
+    for (auto &spindle : stop_spindles) {
+        spindle = {};
+    }
+    if (emcStatus) {
+        emcStatus->task.stopState = EMC_TASK_STOP_STATE::IDLE;
+        if (was_active) {
+            emcStatus->task.task_paused = 0;
+        }
+    }
+}
+
+static void emcTaskStopResume()
+{
+    stop_resume_latched = false;
+    if (!stop_outputs_saved) {
+        return;
+    }
+
+    if (stop_mist) {
+        emcCoolantMistOn();
+    }
+    if (stop_flood) {
+        emcCoolantFloodOn();
+    }
+    for (int s = 0; s < emcStatus->motion.traj.spindles; ++s) {
+        if (stop_spindles[s].running) {
+            emcSpindleOn(s, stop_spindles[s].speed,
+                    stop_spindles[s].css_factor,
+                    stop_spindles[s].css_xoffset, 0);
+        }
+    }
+    emcStatus->task.stopState = EMC_TASK_STOP_STATE::STARTING;
+}
+
+static void emcTaskStopProgress()
+{
+    switch (emcStatus->task.stopState) {
+    case EMC_TASK_STOP_STATE::STOPPING: {
+        if (!emcStatus->motion.traj.stopped) {
+            return;
+        }
+
+        if (!stop_outputs_saved) {
+            stop_mist = emcStatus->io.coolant.mist;
+            stop_flood = emcStatus->io.coolant.flood;
+        }
+        bool spindle_output_active = false;
+        for (int s = 0; s < emcStatus->motion.traj.spindles; ++s) {
+            const auto &status = emcStatus->motion.spindle[s];
+            if (!stop_outputs_saved) {
+                stop_spindles[s].running = status.enabled;
+                stop_spindles[s].speed = status.speed;
+                stop_spindles[s].css_factor = status.css_factor;
+                stop_spindles[s].css_xoffset = status.css_xoffset;
+            }
+            if (status.enabled ||
+                    status.orient_state == EMCMOT_ORIENT_IN_PROGRESS) {
+                emcSpindleOff(s);
+                spindle_output_active = true;
+            }
+        }
+        if (!stop_outputs_saved) {
+            if (stop_mist) {
+                emcCoolantMistOff();
+            }
+            if (stop_flood) {
+                emcCoolantFloodOff();
+            }
+            stop_outputs_saved = true;
+        }
+        if (spindle_output_active) {
+            return;
+        }
+        emcStatus->task.stopState = EMC_TASK_STOP_STATE::STOPPED;
+        if (stop_resume_latched) {
+            emcTaskStopResume();
+        }
+        return;
+    }
